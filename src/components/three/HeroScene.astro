<div id="three-hero-container" class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-95"></div>

<script>
  import * as THREE from 'three';

  const container = document.getElementById('three-hero-container');

  if (container) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 6.5;

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    container.appendChild(renderer.domElement);

    // Lights adapted to Innova UCSP Palette: #254166 (Azul principal), #63242F (Granate), #C5A059 (Dorado elegante)
    const ambientLight = new THREE.AmbientLight(0xF8F6F1, 0.85);
    scene.add(ambientLight);

    const goldLight = new THREE.DirectionalLight(0xC5A059, 3.8);
    goldLight.position.set(5, 5, 4);
    scene.add(goldLight);

    const navyLight = new THREE.DirectionalLight(0x254166, 4.5);
    navyLight.position.set(-5, 3, 4);
    scene.add(navyLight);

    const burgundyLight = new THREE.DirectionalLight(0x63242F, 4.2);
    burgundyLight.position.set(-4, -4, 3);
    scene.add(burgundyLight);

    const silverLight = new THREE.PointLight(0xA7ADB5, 2.5, 15);
    silverLight.position.set(0, 4, -2);
    scene.add(silverLight);

    // Abstract Geometric Group (Obermann Style 3D crystalline structure)
    const group = new THREE.Group();
    scene.add(group);

    // Main material: deep blue-black (#101820) optimized for performance
    const mainMaterial = new THREE.MeshStandardMaterial({
      color: 0x101820,
      emissive: 0x0c1218,
      transparent: true,
      opacity: 0.5,
      roughness: 0.25,
      metalness: 0.5,
      side: THREE.DoubleSide,
      wireframe: false
    });

    const wireframeMaterial = new THREE.MeshBasicMaterial({
      color: 0xC5A059,
      wireframe: true,
      transparent: true,
      opacity: 0.18
    });

    // Outer Icosahedron
    const geo1 = new THREE.IcosahedronGeometry(2.2, 1);
    const mesh1 = new THREE.Mesh(geo1, mainMaterial);
    const wire1 = new THREE.Mesh(geo1, wireframeMaterial);
    group.add(mesh1);
    group.add(wire1);

    // Inner geometric nucleus (Burgundy #63242F / Gold #C5A059 tinted)
    const innerMaterial = new THREE.MeshStandardMaterial({
      color: 0x63242F,
      transparent: true,
      opacity: 0.55,
      roughness: 0.12,
      metalness: 0.65
    });
    const geo2 = new THREE.OctahedronGeometry(1.2, 0);
    const mesh2 = new THREE.Mesh(geo2, innerMaterial);
    mesh2.rotation.set(0.5, 0.5, 0);
    group.add(mesh2);

    // Floating outer crystalline shards (Sage / Sky / Sand accents)
    const shardGeo = new THREE.TetrahedronGeometry(0.4, 0);
    const shardPositions = [
      [-3.0, 1.8, -1.0],
      [3.2, -1.5, 0.5],
      [1.8, 2.6, 1.2],
      [-2.2, -2.4, -0.8]
    ];
    shardPositions.forEach((pos, idx) => {
      const shard = new THREE.Mesh(shardGeo, idx % 2 === 0 ? mainMaterial : wireframeMaterial);
      shard.position.set(pos[0], pos[1], pos[2]);
      group.add(shard);
    });

    // Mouse interactive tilt
    let mouseX = 0;
    let mouseY = 0;
    const windowHalfX = window.innerWidth / 2;
    const windowHalfY = window.innerHeight / 2;

    window.addEventListener('mousemove', (event) => {
      mouseX = (event.clientX - windowHalfX) * 0.0008;
      mouseY = (event.clientY - windowHalfY) * 0.0008;
    });

    // Resize handling
    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    // Animation Loop
    const clock = new THREE.Clock();
    function animate() {
      requestAnimationFrame(animate);
      const elapsed = clock.getElapsedTime();

      group.rotation.x += 0.0015;
      group.rotation.y += 0.0025;

      // Subtle pulse and mouse reaction
      group.position.y = Math.sin(elapsed * 0.8) * 0.15;
      group.rotation.x += (mouseY - group.rotation.x) * 0.05;
      group.rotation.y += (mouseX - group.rotation.y) * 0.05;

      mesh2.rotation.y -= 0.008;
      mesh2.rotation.z += 0.005;

      renderer.render(scene, camera);
    }
    animate();
  }
</script>
