<div id="three-hero-container" class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-90"></div>

<script>
  import * as THREE from 'three';

  const container = document.getElementById('three-hero-container');

  if (container) {
    const scene = new THREE.Scene();
    
    // Narrow FOV (25) prevents "egg" distortion (perspective stretching) at the edges of the screen
    const camera = new THREE.PerspectiveCamera(25, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 15;

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: "high-performance" });
    renderer.setSize(window.innerWidth, window.innerHeight);
    // Cap pixel ratio to 1.2 for massive performance boost, especially on high-DPI mobile screens
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.2));
    container.appendChild(renderer.domElement);

    const group = new THREE.Group();
    scene.add(group);

    const innerGroup = new THREE.Group();
    const outerGroup = new THREE.Group();
    group.add(innerGroup);
    group.add(outerGroup);

    const isMobile = window.innerWidth < 768;

    // Particle material
    // Disabling transparency and blending avoids expensive GPU depth sorting and overdraw (massive FPS boost)
    const particleMaterial = new THREE.PointsMaterial({
      size: isMobile ? 0.08 : 0.12, // Larger particles to compensate for lower point count
      transparent: false, 
      vertexColors: true
    });

    // Load Image and create particles
    const img = new Image();
    img.src = '/favicon.webp';
    img.crossOrigin = 'Anonymous';
    img.onload = () => {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      // Lower resolution drastically reduces vertex count (100 = 10k points max vs 32k)
      const res = isMobile ? 100 : 120;
      canvas.width = res;
      canvas.height = res;
      ctx.drawImage(img, 0, 0, res, res);
      const data = ctx.getImageData(0, 0, res, res).data;

      const innerPositions = [];
      const innerColors = [];
      const outerPositions = [];
      const outerColors = [];

      const colorBlue = new THREE.Color(0x254166);
      const colorRed = new THREE.Color(0x63242F);
      const colorGold = new THREE.Color(0xC5A059);

      for (let y = 0; y < res; y++) {
        for (let x = 0; x < res; x++) {
          const idx = (y * res + x) * 4;
          const r = data[idx];
          const g = data[idx+1];
          const b = data[idx+2];
          const a = data[idx+3];

          // Ignore transparent pixels AND ignore white/light-gray background/noise pixels
          const isWhiteBackground = (r > 180 && g > 180 && b > 180);

          if (a > 100 && !isWhiteBackground) { 
            // Normalized coords from -1 to 1
            const nx = (x / res) * 2 - 1;
            const ny = -(y / res) * 2 + 1; 

            // Calculate distance from center to crop into a perfect circle
            const dist = Math.sqrt(nx*nx + ny*ny);

            // Strictly ignore anything outside a circle (removes corner noise)
            if (dist > 0.95) continue;
            
            // Give it 3D depth volume (random z)
            const nz = (Math.random() - 0.5) * 0.4; 

            // Scale up the points in the 3D space. Make it much smaller on mobile so it fits the narrow screen width.
            const scale = isMobile ? 1.6 : 4.8;
            const px = nx * scale;
            const py = ny * scale;
            const pz = nz * scale;

            // Use a slightly elliptical distance check to safely enclose the tall 'i' and its crescent
            const ellipticalDist = Math.sqrt(nx*nx + (ny*ny)*0.7);

            // Use the actual pixel color from the image, just boosted slightly so it glows
            const particleColor = new THREE.Color(r/255, g/255, b/255).lerp(new THREE.Color(0xffffff), 0.15);
            
            // The white gap in the logo is around 0.38 radius
            if (ellipticalDist < 0.39) {
              innerPositions.push(px, py, pz);
              innerColors.push(particleColor.r, particleColor.g, particleColor.b);
            } else {
              outerPositions.push(px, py, pz);
              outerColors.push(particleColor.r, particleColor.g, particleColor.b);
            }
          }
        }
      }

      const innerGeo = new THREE.BufferGeometry();
      innerGeo.setAttribute('position', new THREE.Float32BufferAttribute(innerPositions, 3));
      innerGeo.setAttribute('color', new THREE.Float32BufferAttribute(innerColors, 3));
      const innerPoints = new THREE.Points(innerGeo, particleMaterial);
      innerGroup.add(innerPoints);

      const outerGeo = new THREE.BufferGeometry();
      outerGeo.setAttribute('position', new THREE.Float32BufferAttribute(outerPositions, 3));
      outerGeo.setAttribute('color', new THREE.Float32BufferAttribute(outerColors, 3));
      const outerPoints = new THREE.Points(outerGeo, particleMaterial);
      outerGroup.add(outerPoints);
    };

    // Mouse interactive tilt
    let mouseX = 0;
    let mouseY = 0;
    const windowHalfX = window.innerWidth / 2;
    const windowHalfY = window.innerHeight / 2;

    window.addEventListener('mousemove', (event) => {
      mouseX = (event.clientX - windowHalfX) * 0.0008;
      mouseY = (event.clientY - windowHalfY) * 0.0008;
    });

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    const clock = new THREE.Clock();
    function animate() {
      requestAnimationFrame(animate);
      const elapsed = clock.getElapsedTime();

      // Outer gear rotates constantly
      outerGroup.rotation.z -= 0.003; 

      // Subtle 3D bobbing and mouse reaction for the whole group
      const targetX = 0; // Keeps it strictly in the center
      
      group.position.x += (targetX - group.position.x) * 0.05;
      group.position.y = Math.sin(elapsed * 0.5) * 0.1;
      
      // Add slight 3D perspective tilt
      const targetRotationX = mouseY + 0.1; // Default slight tilt
      const targetRotationY = mouseX - 0.1;

      group.rotation.x += (targetRotationX - group.rotation.x) * 0.05;
      group.rotation.y += (targetRotationY - group.rotation.y) * 0.05;

      renderer.render(scene, camera);
    }
    animate();
  }
</script>
