---
import { PROCESS_STEPS } from '../../data/portfolioData';
---

<section id="metodologia" class="relative py-32 px-6 sm:px-12 max-w-7xl mx-auto overflow-hidden">
  
  <div class="space-y-20 relative z-10">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-l-2 border-[#d4af37] pl-6">
      <div class="space-y-3">
        <span class="text-xs uppercase tracking-widest text-[#d4af37] font-mono font-semibold">06. Metodología & Proceso</span>
        <h2 class="section-title font-display text-white">
          Proceso de <span class="font-serif italic font-normal text-gradient-gold">5 Pasos</span>
        </h2>
      </div>
      <p class="text-sm text-slate-400 font-light max-w-md">
        Desde la conceptualización ágil con PMO hasta el despliegue tecnológico y la articulación interinstitucional en la UCSP.
      </p>
    </div>

    <!-- Numbered Process Rows (Obermann Style) -->
    <div class="space-y-4">
      {PROCESS_STEPS.map((step, idx) => (
        <div class="process-item relative group py-12 px-6 sm:px-10 border-t border-white/15 first:border-t-0 flex flex-col md:flex-row items-start md:items-center justify-between gap-8 glass-panel glass-panel-hover rounded-3xl overflow-hidden">
          
          <!-- Background Huge Number watermark -->
          <div class="process-number absolute right-6 top-1/2 -translate-y-1/2 font-display font-extrabold text-6xl sm:text-9xl text-white/[0.04] select-none pointer-events-none group-hover:text-[#d4af37]/15 transition-colors duration-500">
            {step.number}
          </div>

          <!-- Step Number & Subtitle -->
          <div class="flex items-center gap-6 relative z-10 md:w-1/3">
            <span class="font-display font-bold text-3xl sm:text-4xl text-[#d4af37] font-mono">
              {step.number}
            </span>
            <div class="space-y-1">
              <span class="text-[11px] font-mono uppercase tracking-widest text-slate-400 font-semibold block">
                {step.subtitle}
              </span>
              <h3 class="font-display font-bold text-2xl sm:text-3xl text-white group-hover:text-[#f3e5ab] transition-colors">
                {step.title}
              </h3>
            </div>
          </div>

          <!-- Description -->
          <div class="relative z-10 md:w-2/3 md:pl-10 border-l border-transparent md:border-white/10">
            <p class="text-base sm:text-lg text-slate-300 font-light leading-relaxed max-w-2xl">
              {step.description}
            </p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.process-item');
    items.forEach((item) => {
      const num = item.querySelector('.process-number');
      if (num) {
        gsap.from(num, {
          opacity: 0,
          scale: 0.7,
          scrollTrigger: {
            trigger: item,
            start: 'top 80%',
            end: 'bottom 20%',
            toggleActions: 'play none none reverse'
          }
        });
      }
    });
  });
</script>
