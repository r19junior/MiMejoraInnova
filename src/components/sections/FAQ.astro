---
import { FAQ_ITEMS } from '../../data/portfolioData';
---

<section id="faq" class="relative py-32 px-6 sm:px-12 max-w-5xl mx-auto overflow-hidden">
  
  <div class="space-y-16 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center space-y-4 max-w-3xl mx-auto">
      <span class="text-xs uppercase tracking-widest text-[#C5A059] font-mono font-semibold">08. Consultas & Claridad</span>
      <h2 class="section-title font-display text-[#F8F6F1]">
        Preguntas <span class="font-serif italic font-normal text-gradient-gold">Frecuentes</span>
      </h2>
      <p class="text-sm sm:text-base text-[#A7ADB5] font-light max-w-xl mx-auto">
        Todo lo que necesitas saber sobre nuestra comunidad en la UCSP, la postulación y cómo colaboramos en proyectos interinstitucionales.
      </p>
    </div>

    <!-- GSAP Animated Accordion List (Obermann Style) -->
    <div class="space-y-4">
      {FAQ_ITEMS.map((faq, idx) => (
        <div class="faq-item glass-panel rounded-2xl border border-[#E5E7EB]/15 overflow-hidden transition-colors duration-300">
          
          <button
            type="button"
            class="faq-trigger w-full p-6 sm:p-8 text-left flex items-center justify-between gap-6 focus:outline-none group"
            aria-expanded="false"
          >
            <div class="flex items-center gap-4">
              <span class="font-mono text-xs font-bold text-[#C5A059]">0{idx + 1}</span>
              <span class="font-display font-semibold text-lg sm:text-xl text-[#F8F6F1] group-hover:text-[#D8C7A5] transition-colors">
                {faq.question}
              </span>
            </div>

            <!-- Plus / Minus Icon -->
            <div class="faq-icon-wrap w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-[#A7ADB5] group-hover:text-[#F8F6F1] group-hover:bg-[#C5A059]/20 transition-all shrink-0">
              <svg class="faq-icon-plus w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              <svg class="faq-icon-minus w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
              </svg>
            </div>
          </button>

          <!-- Collapsible Content -->
          <div class="faq-content h-0 overflow-hidden opacity-0">
            <div class="px-6 pb-8 sm:px-8 sm:pb-8 pt-2 border-t border-[#E5E7EB]/10 text-sm sm:text-base text-[#E5E7EB] font-light leading-relaxed">
              {faq.answer}
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Still have questions box -->
    <div class="text-center pt-8">
      <p class="text-xs font-mono text-[#A7ADB5]">
        ¿Tienes otra consulta o propuesta institucional? 
        <a href="#contacto" class="text-[#C5A059] font-bold hover:underline ml-1">Contáctanos directamente →</a>
      </p>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';

  window.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach((item) => {
      const trigger = item.querySelector('.faq-trigger');
      const content = item.querySelector('.faq-content') as HTMLElement;
      const plus = item.querySelector('.faq-icon-plus');
      const minus = item.querySelector('.faq-icon-minus');

      if (!trigger || !content) return;

      let isOpen = false;

      trigger.addEventListener('click', () => {
        if (!isOpen) {
          isOpen = true;
          trigger.setAttribute('aria-expanded', 'true');
          item.classList.add('border-[#C5A059]/50', 'bg-[#30343B]/80');
          plus?.classList.add('hidden');
          minus?.classList.remove('hidden');

          gsap.to(content, {
            height: 'auto',
            opacity: 1,
            duration: 0.45,
            ease: 'power3.out'
          });
        } else {
          isOpen = false;
          trigger.setAttribute('aria-expanded', 'false');
          item.classList.remove('border-[#C5A059]/50', 'bg-[#30343B]/80');
          plus?.classList.remove('hidden');
          minus?.classList.add('hidden');

          gsap.to(content, {
            height: 0,
            opacity: 0,
            duration: 0.35,
            ease: 'power3.inOut'
          });
        }
      });
    });
  });
</script>
