---
import { DIRECTIVA } from '../../data/portfolioData';
---

<section id="directiva" class="relative py-32 px-6 sm:px-12 max-w-7xl mx-auto">
  
  <div class="space-y-16 relative z-10">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-l-2 border-[#d4af37] pl-6">
      <div class="space-y-3">
        <span class="text-xs uppercase tracking-widest text-[#d4af37] font-mono font-semibold">03. Equipo Directivo</span>
        <h2 class="section-title font-display text-white">
          Directiva <span class="font-serif italic font-normal text-gradient-gold">Innova UCSP</span>
        </h2>
      </div>
      <p class="text-sm text-slate-400 font-light max-w-md">
        Líderes apasionados por la innovación institucional, la gestión ágil de proyectos y la articulación tecnológica de alto nivel.
      </p>
    </div>

    <!-- Leadership Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      {DIRECTIVA.map((member) => (
        <div class="glass-panel glass-panel-hover rounded-3xl p-6 relative overflow-hidden flex flex-col justify-between group border border-white/10">
          
          <div class="space-y-4">
            <div class="aspect-[4/5] w-full rounded-2xl overflow-hidden relative bg-[#1c161a]">
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500 filter contrast-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0e]/90 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
            </div>

            <div class="space-y-1 pt-1">
              <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-widest bg-[#d4af37]/15 text-[#d4af37] border border-[#d4af37]/30">
                {member.role}
              </span>
              <h3 class="font-display font-bold text-base sm:text-lg text-white pt-1 group-hover:text-[#f3e5ab] transition-colors leading-snug">
                {member.name}
              </h3>
            </div>
          </div>

          <div class="pt-4 mt-4 border-t border-white/10 flex items-center justify-between text-xs font-mono text-slate-500">
            <span>Comité Ejecutivo</span>
            <span class="text-white/40 group-hover:text-[#d4af37] transition-colors">✦ UCSP</span>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
