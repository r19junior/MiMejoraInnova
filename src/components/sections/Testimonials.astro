---
import { INNOVA_INFO } from '../../data/portfolioData';
---

<section id="mision-vision" class="relative py-32 px-6 sm:px-12 max-w-7xl mx-auto overflow-hidden">
  
  <!-- Subtle ambient glow using Innova Colors (#254166 / #63242F / #C5A059) -->
  <div class="absolute top-1/2 left-0 w-96 h-96 bg-[#254166]/15 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#63242F]/15 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="space-y-20 relative z-10">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-l-2 border-[#C5A059] pl-6">
      <div class="space-y-3">
        <span class="text-xs uppercase tracking-widest text-[#C5A059] font-mono font-semibold">01. Filosofía & Propósito</span>
        <h2 class="section-title font-display text-[#F8F6F1]">
          Misión & <span class="font-serif italic font-normal text-gradient-gold">Visión Institucional</span>
        </h2>
      </div>
      <p class="text-sm text-[#A7ADB5] font-light max-w-md">
        Nuestros pilares rectores para impulsar el liderazgo y el desarrollo tecnológico en la Universidad Católica San Pablo (UCSP).
      </p>
    </div>

    <!-- Editorial Quotes Grid (Misión & Visión) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch">
      
      <!-- Misión Card (Borde superior y acento Azul Marino #254166) -->
      <div class="glass-panel glass-panel-hover p-10 sm:p-14 rounded-3xl relative overflow-hidden flex flex-col justify-between space-y-8 border-t-4 border-t-[#254166] group">
        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <span class="px-4 py-1 rounded-full text-xs font-mono font-bold uppercase tracking-widest bg-[#254166]/30 text-[#8FAFC4] border border-[#254166]/50">
              Nuestra Misión
            </span>
            <span class="text-4xl font-serif text-[#E5E7EB]/20 select-none">“</span>
          </div>
          
          <h3 class="font-display font-semibold text-2xl sm:text-3xl text-[#F8F6F1] group-hover:text-[#8FAFC4] transition-colors leading-snug">
            Cultura Sólida de Gestión de Proyectos en la UCSP
          </h3>

          <p class="text-base sm:text-lg text-[#E5E7EB] font-light leading-relaxed">
            "{INNOVA_INFO.mission}"
          </p>
        </div>

        <div class="pt-6 border-t border-[#E5E7EB]/10 flex items-center justify-between text-xs font-mono text-[#A7ADB5]">
          <span>Excelencia Académica & Autonomía</span>
          <span class="text-[#C5A059]">✦ Innova UCSP</span>
        </div>
      </div>

      <!-- Visión Card (Borde superior y acento Granate/Borgoña #63242F y Dorado #C5A059) -->
      <div class="glass-panel glass-panel-hover p-10 sm:p-14 rounded-3xl relative overflow-hidden flex flex-col justify-between space-y-8 border-t-4 border-t-[#63242F] group">
        <div class="space-y-6">
          <div class="flex items-center justify-between">
            <span class="px-4 py-1 rounded-full text-xs font-mono font-bold uppercase tracking-widest bg-[#63242F]/30 text-[#D8C7A5] border border-[#63242F]/50">
              Nuestra Visión
            </span>
            <span class="text-4xl font-serif text-[#E5E7EB]/20 select-none">“</span>
          </div>

          <h3 class="font-display font-semibold text-2xl sm:text-3xl text-[#F8F6F1] group-hover:text-[#D8C7A5] transition-colors leading-snug">
            Comunidad Referente en Soluciones Innovadoras
          </h3>

          <p class="text-base sm:text-lg text-[#E5E7EB] font-light leading-relaxed">
            "{INNOVA_INFO.vision}"
          </p>
        </div>

        <div class="pt-6 border-t border-[#E5E7EB]/10 flex items-center justify-between text-xs font-mono text-[#A7ADB5]">
          <span>Cooperación Interdisciplinaria & Sostenibilidad</span>
          <span class="text-[#C5A059]">✦ Innova UCSP</span>
        </div>
      </div>

    </div>

    <!-- Editorial Endorsement Banner -->
    <div class="glass-panel p-8 rounded-2xl flex flex-col sm:flex-row items-center justify-between gap-6 border-l border-r border-[#C5A059]/35">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-[#C5A059]/15 flex items-center justify-center text-[#C5A059] text-xl font-bold font-serif">
          ★
        </div>
        <div>
          <h4 class="font-display font-bold text-[#F8F6F1] text-lg">Comunidad Estudiantil de Alto Impacto</h4>
          <p class="text-xs text-[#A7ADB5] font-light">Especializados en metodologías PMO, desarrollo web TI e integración interinstitucional.</p>
        </div>
      </div>
      <a href="#areas" class="px-6 py-3 rounded-full text-xs font-bold uppercase tracking-widest bg-white/10 hover:bg-[#C5A059] text-[#F8F6F1] hover:text-[#101820] transition-all duration-300 whitespace-nowrap">
        Conoce Nuestras 6 Áreas
      </a>
    </div>

  </div>
</section>
