---
import { INNOVA_INFO, REDES_SOCIALES } from '../../data/portfolioData';
---

<section id="contacto" class="relative py-32 px-6 sm:px-12 max-w-7xl mx-auto overflow-hidden">
  
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start relative z-10">
    
    <!-- Left Column: Editorial Call to Action & Social -->
    <div class="lg:col-span-5 space-y-10 lg:sticky lg:top-28">
      
      <div class="space-y-4">
        <span class="text-xs uppercase tracking-widest text-[#C5A059] font-mono font-semibold">09. Conexión & Comunidad</span>
        <h2 class="hero-title font-display text-[#F8F6F1] leading-none">
          Hablemos <span class="block font-serif italic font-normal text-gradient-gold">del Futuro</span>
        </h2>
        <p class="text-base text-[#E5E7EB] font-light leading-relaxed pt-2">
          ¿Tienes una propuesta para nuestras 6 áreas, deseas postular a Innova UCSP o coordinar una alianza estratégica? Escríbenos y hagámoslo realidad.
        </p>
      </div>

      <!-- Institutional Contact Details -->
      <div class="space-y-6 pt-4 border-t border-[#E5E7EB]/15 font-mono text-sm">
        <div class="space-y-1">
          <span class="text-xs uppercase text-[#A7ADB5]">Correo Institucional</span>
          <a href={`mailto:${INNOVA_INFO.contactEmail}`} class="block text-base text-[#F8F6F1] hover:text-[#C5A059] transition-colors font-semibold">
            {INNOVA_INFO.contactEmail}
          </a>
        </div>

        <div class="space-y-1">
          <span class="text-xs uppercase text-[#A7ADB5]">Ubicación & Campus</span>
          <p class="text-base text-[#E5E7EB] font-light">
            {INNOVA_INFO.location}
          </p>
        </div>
      </div>

      <!-- Social Media Grid -->
      <div class="space-y-4 pt-4 border-t border-[#E5E7EB]/15">
        <span class="text-xs font-mono uppercase tracking-widest text-[#A7ADB5] block">Nuestras Redes Oficiales</span>
        <div class="grid grid-cols-2 gap-3">
          {REDES_SOCIALES.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="glass-panel glass-panel-hover p-4 rounded-2xl flex items-center gap-3.5 group transition-all"
            >
              <div class="w-8 h-8 rounded-lg overflow-hidden bg-white/10 shrink-0 flex items-center justify-center p-1 border border-[#E5E7EB]/15">
                <img
                  src={social.iconImage}
                  alt={social.platform}
                  class="w-full h-full object-contain filter contrast-125 group-hover:scale-110 transition-transform"
                />
              </div>
              <span class="text-xs font-mono font-bold text-[#F8F6F1] group-hover:text-[#C5A059] transition-colors">
                {social.platform}
              </span>
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- Right Column: Editorial Contact Form (Obermann Style) -->
    <div class="lg:col-span-7 glass-panel p-8 sm:p-14 rounded-3xl space-y-8 border border-[#E5E7EB]/15">
      
      <div class="space-y-2 border-b border-[#E5E7EB]/15 pb-6">
        <h3 class="font-display font-bold text-2xl sm:text-3xl text-[#F8F6F1]">
          Envía tu Mensaje Institucional
        </h3>
        <p class="text-sm text-[#A7ADB5] font-light">
          Completa el formulario y nos pondremos en contacto contigo a la brevedad posible.
        </p>
      </div>

      <form id="editorial-contact-form" class="space-y-8" novalidate>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="space-y-1">
            <label for="name" class="text-xs font-mono uppercase tracking-widest text-[#A7ADB5]">01. Tu Nombre Completo *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Ej. Carlos Mendoza"
              class="form-field"
            />
            <span class="error-msg text-xs font-mono text-rose-400 hidden">Por favor ingresa tu nombre.</span>
          </div>

          <div class="space-y-1">
            <label for="email" class="text-xs font-mono uppercase tracking-widest text-[#A7ADB5]">02. Tu Correo Electrónico *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="carlos@ucsp.edu.pe"
              class="form-field"
            />
            <span class="error-msg text-xs font-mono text-rose-400 hidden">Ingresa un correo electrónico válido.</span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="space-y-1">
            <label for="organization" class="text-xs font-mono uppercase tracking-widest text-[#A7ADB5]">03. Universidad u Organización</label>
            <input
              type="text"
              id="organization"
              name="organization"
              placeholder="Ej. UCSP / Estudiante TI"
              class="form-field"
            />
          </div>

          <div class="space-y-1">
            <label for="area-select" class="text-xs font-mono uppercase tracking-widest text-[#A7ADB5]">04. Área de Interés</label>
            <select
              id="area-select"
              name="area"
              class="form-field text-[#F8F6F1] bg-[#101820] cursor-pointer"
            >
              <option value="general" class="bg-[#101820]">Consulta General / Postulación</option>
              <option value="ti" class="bg-[#101820]">Área de TI (Desarrollo & Tech)</option>
              <option value="pmo" class="bg-[#101820]">Área de P.M.O (Gestión)</option>
              <option value="mkt" class="bg-[#101820]">Área de Marketing & Branding</option>
              <option value="ri" class="bg-[#101820]">Relaciones Interinstitucionales</option>
              <option value="th" class="bg-[#101820]">Talento Humano</option>
              <option value="log" class="bg-[#101820]">Logística & Eventos</option>
            </select>
          </div>
        </div>

        <div class="space-y-1">
          <label for="message" class="text-xs font-mono uppercase tracking-widest text-[#A7ADB5]">05. Cuéntanos sobre tu iniciativa o consulta *</label>
          <textarea
            id="message"
            name="message"
            rows="3"
            required
            placeholder="Escribe tu mensaje, propuesta de evento o inquietud..."
            class="form-field resize-none"
          ></textarea>
          <span class="error-msg text-xs font-mono text-rose-400 hidden">El mensaje es obligatorio (mínimo 10 caracteres).</span>
        </div>

        <!-- Submit Button -->
        <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-[#E5E7EB]/15">
          <button
            type="submit"
            id="submit-btn"
            class="button-primary w-full sm:w-auto group"
          >
            <span id="btn-text">Enviar Mensaje</span>
            <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>

          <span id="form-feedback" class="text-xs font-mono text-[#C5A059] hidden">
            ✓ ¡Mensaje enviado con éxito! Nos comunicaremos pronto.
          </span>
        </div>

      </form>

    </div>

  </div>
</section>

<script>
  const form = document.getElementById('editorial-contact-form') as HTMLFormElement;
  const feedback = document.getElementById('form-feedback');
  const btnText = document.getElementById('btn-text');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const nameInput = form.querySelector('#name') as HTMLInputElement;
    const emailInput = form.querySelector('#email') as HTMLInputElement;
    const msgInput = form.querySelector('#message') as HTMLTextAreaElement;

    let valid = true;

    if (!nameInput.value.trim()) {
      valid = false;
      nameInput.parentElement?.querySelector('.error-msg')?.classList.remove('hidden');
    } else {
      nameInput.parentElement?.querySelector('.error-msg')?.classList.add('hidden');
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailInput.value.trim() || !emailRegex.test(emailInput.value)) {
      valid = false;
      emailInput.parentElement?.querySelector('.error-msg')?.classList.remove('hidden');
    } else {
      emailInput.parentElement?.querySelector('.error-msg')?.classList.add('hidden');
    }

    if (!msgInput.value.trim() || msgInput.value.trim().length < 10) {
      valid = false;
      msgInput.parentElement?.querySelector('.error-msg')?.classList.remove('hidden');
    } else {
      msgInput.parentElement?.querySelector('.error-msg')?.classList.add('hidden');
    }

    if (valid) {
      if (btnText) btnText.textContent = 'Enviando...';
      const submitBtn = form.querySelector('#submit-btn') as HTMLButtonElement;
      if (submitBtn) submitBtn.disabled = true;

      setTimeout(() => {
        form.reset();
        if (btnText) btnText.textContent = 'Mensaje Enviado';
        feedback?.classList.remove('hidden');
        setTimeout(() => {
          if (btnText) btnText.textContent = 'Enviar Otro Mensaje';
          if (submitBtn) submitBtn.disabled = false;
          feedback?.classList.add('hidden');
        }, 5000);
      }, 1200);
    }
  });
</script>
