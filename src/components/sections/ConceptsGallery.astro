---
import { PROJECTS_AND_MILESTONES } from '../../data/portfolioData';
---

<section id="proyectos" class="relative py-32 px-6 sm:px-12 max-w-7xl mx-auto overflow-hidden">
  
  <div class="space-y-16 relative z-10">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-l-2 border-[#d4af37] pl-6">
      <div class="space-y-3">
        <span class="text-xs uppercase tracking-widest text-[#d4af37] font-mono font-semibold">04. Proyectos & Galería</span>
        <h2 class="section-title font-display text-white">
          Hitos & <span class="font-serif italic font-normal text-gradient-gold">Proyectos Destacados</span>
        </h2>
      </div>
      <p class="text-sm text-slate-400 font-light max-w-md">
        Nuestras principales iniciativas de impacto universitario, congresos internacionales, voluntariados y alianzas interinstitucionales.
      </p>
    </div>

    <!-- Featured Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
      {PROJECTS_AND_MILESTONES.filter(p => p.featured).map((project, idx) => (
        <div class="glass-panel glass-panel-hover rounded-3xl overflow-hidden group flex flex-col justify-between border border-white/10">
          
          <div class="relative aspect-[16/10] w-full overflow-hidden bg-[#1c161a]">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 opacity-90 group-hover:opacity-100"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0e] via-transparent to-transparent"></div>
            <div class="absolute top-5 left-5 z-10">
              <span class="px-3.5 py-1 rounded-full text-[11px] font-mono font-bold uppercase tracking-wider bg-[#0a0a0e]/80 backdrop-blur-md text-[#d4af37] border border-[#d4af37]/30">
                {project.category}
              </span>
            </div>
          </div>

          <div class="p-8 flex flex-col justify-between space-y-4">
            <div class="space-y-2">
              <span class="text-xs font-mono uppercase tracking-widest text-slate-500">
                Iniciativa Destacada #{idx + 1}
              </span>
              <h3 class="font-display font-bold text-2xl text-white group-hover:text-[#d4af37] transition-colors">
                {project.title}
              </h3>
              <p class="text-sm text-slate-300 font-light leading-relaxed">
                {project.description}
              </p>
            </div>

            <div class="pt-4 border-t border-white/10 flex items-center justify-between text-xs font-mono text-[#d4af37]">
              <span>✦ Impacto Institucional UCSP</span>
              <span class="group-hover:translate-x-1 transition-transform inline-block">Ver detalles →</span>
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Secondary Milestones Carousel / Grid -->
    <div class="space-y-8 pt-12 border-t border-white/10">
      <h3 class="font-display font-bold text-2xl text-white">Otras Actividades & Alianzas Estratégicas</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {PROJECTS_AND_MILESTONES.filter(p => !p.featured).map((milestone) => (
          <div class="glass-panel glass-panel-hover p-6 rounded-2xl flex flex-col justify-between space-y-4 border border-white/10 group">
            <div class="aspect-[16/9] w-full rounded-xl overflow-hidden relative bg-[#1c161a]">
              <img
                src={milestone.image}
                alt={milestone.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-80 group-hover:opacity-100"
                loading="lazy"
              />
            </div>
            <div class="space-y-2">
              <span class="px-2.5 py-0.5 rounded font-mono text-[10px] font-semibold uppercase bg-[#d4af37]/10 text-[#d4af37]">
                {milestone.category}
              </span>
              <h4 class="font-display font-bold text-lg text-white group-hover:text-[#f3e5ab] transition-colors leading-snug">
                {milestone.title}
              </h4>
              <p class="text-xs text-slate-400 leading-relaxed font-light">
                {milestone.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
