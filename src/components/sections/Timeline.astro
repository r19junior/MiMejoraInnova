---
import { TIMELINE } from '../../data/portfolioData';

const typeColors: Record<string, { badge: string; border: string }> = {
  leadership: {
    badge: 'bg-[#d4af37]/10 text-[#d4af37] border-[#d4af37]/30',
    border: 'border-l-[#d4af37]'
  },
  tech: {
    badge: 'bg-blue-500/10 text-blue-400 border-blue-500/30',
    border: 'border-l-blue-400'
  },
  innovation: {
    badge: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30',
    border: 'border-l-emerald-400'
  }
};

const typeLabels: Record<string, string> = {
  leadership: 'Dirección & Liderazgo',
  tech: 'Desarrollo & Tecnología',
  innovation: 'Innovación & Estrategia'
};
---

<section id="trayectoria" class="relative py-32 px-6 lg:px-8 max-w-5xl mx-auto">
  
  <div class="space-y-16 relative z-10">
    
    <!-- Section Header -->
    <div class="space-y-3 border-l-2 border-[#d4af37] pl-6">
      <span class="text-xs uppercase tracking-widest text-[#d4af37] font-semibold">03. Evolución Profesional</span>
      <h2 class="font-display font-bold text-3xl sm:text-5xl text-white tracking-tight">
        Trayectoria & <span class="font-serif italic font-normal text-gradient-gold">Liderazgo</span>
      </h2>
      <p class="text-sm text-slate-400 font-light max-w-xl">
        Hitos clave en la dirección de tecnologías, gestión institucional y especialización técnica continuada en el ecosistema UCSP.
      </p>
    </div>

    <!-- Vertical Timeline -->
    <div class="relative pl-6 sm:pl-10 border-l border-white/15 space-y-12">
      {TIMELINE.map((item, idx) => {
        const styles = typeColors[item.type] || typeColors.leadership;
        return (
          <div class="relative group">
            
            <!-- Timeline Dot -->
            <div class="absolute -left-[31px] sm:-left-[47px] top-1.5 w-5 h-5 rounded-full bg-[#0a0a0c] border-2 border-[#d4af37] flex items-center justify-center group-hover:scale-125 transition-transform duration-300 shadow-md shadow-[#d4af37]/40">
              <div class="w-2 h-2 rounded-full bg-[#d4af37]"></div>
            </div>

            <!-- Card Content -->
            <div class={`glass-panel glass-panel-hover p-6 sm:p-8 rounded-3xl border-l-4 ${styles.border} space-y-4`}>
              
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-white/10 pb-4">
                <div class="space-y-1">
                  <span class={`inline-block px-3 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider border ${styles.badge}`}>
                    {typeLabels[item.type] || 'Gestión'}
                  </span>
                  <h3 class="font-display font-bold text-xl sm:text-2xl text-white pt-1">
                    {item.role}
                  </h3>
                  <span class="block text-sm font-medium text-[#e2e8f0]">
                    {item.organization}
                  </span>
                </div>
                <div class="sm:text-right">
                  <span class="inline-block px-3 py-1 rounded-lg bg-white/5 font-mono text-xs text-[#d4af37]">
                    {item.period}
                  </span>
                </div>
              </div>

              <p class="text-sm sm:text-base text-slate-300 font-light leading-relaxed">
                {item.description}
              </p>

              <!-- Achievements checklist -->
              <div class="space-y-2 pt-2">
                <h4 class="text-xs uppercase tracking-widest font-semibold text-slate-400">Hitos Clave del Rol:</h4>
                <ul class="space-y-2">
                  {item.achievements.map(ach => (
                    <li class="flex items-start gap-2.5 text-xs sm:text-sm text-slate-300 font-light">
                      <span class="text-[#d4af37] mt-0.5">✦</span>
                      <span>{ach}</span>
                    </li>
                  ))}
                </ul>
              </div>

            </div>

          </div>
        );
      })}
    </div>

  </div>
</section>
