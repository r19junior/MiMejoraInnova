---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { INNOVA_INFO } from '../data/portfolioData';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${INNOVA_INFO.name} — Portfolio Interactivo & Comunidad Tecnológica`,
  description = INNOVA_INFO.heroDescription
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={INNOVA_INFO.name} />
    
    <!-- OpenGraph / Social Meta -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />

    <!-- Google Fonts: Inter, Outfit, Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#101820] text-[#F8F6F1] antialiased selection:bg-[#C5A059] selection:text-[#101820] relative">
    
    <!-- Dynamic Scroll Background -->
    <div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden bg-[#101820]">
      <!-- Orb 1: Blue-ish -->
      <div id="orb-1" class="absolute -top-[20%] -left-[10%] w-[70vw] h-[70vw] max-w-[800px] max-h-[800px] rounded-full opacity-30 mix-blend-screen filter blur-[100px] transition-transform duration-700 ease-out" style="background: radial-gradient(circle, rgba(37,65,102,0.8) 0%, rgba(16,24,32,0) 70%);"></div>
      
      <!-- Orb 2: Red-ish/Wine (Starts bottom right) -->
      <div id="orb-2" class="absolute -bottom-[10%] -right-[10%] w-[80vw] h-[50vw] max-w-[900px] max-h-[600px] rounded-[40%] opacity-30 mix-blend-screen filter blur-[90px] transition-transform duration-700 ease-out" style="background: radial-gradient(ellipse, rgba(99,36,47,0.9) 0%, rgba(16,24,32,0) 70%);"></div>
      
      <!-- Orb 3: Gold Center -->
      <div id="orb-3" class="absolute top-[20%] left-[30%] w-[60vw] h-[60vw] max-w-[700px] max-h-[700px] rounded-full opacity-10 mix-blend-screen filter blur-[120px] transition-transform duration-700 ease-out" style="background: radial-gradient(circle, rgba(197,160,89,0.8) 0%, rgba(16,24,32,0) 70%);"></div>
    </div>

    <script>
      // Scroll-driven animation for the background orbs
      document.addEventListener('DOMContentLoaded', () => {
        const orb1 = document.getElementById('orb-1');
        const orb2 = document.getElementById('orb-2');
        const orb3 = document.getElementById('orb-3');

        window.addEventListener('scroll', () => {
          // Calculate scroll percentage
          const scrollY = window.scrollY;
          const maxScroll = document.body.scrollHeight - window.innerHeight;
          const scrollPercent = maxScroll > 0 ? scrollY / maxScroll : 0;

          // Parallax movement based on scroll percent
          if (orb1) {
            orb1.style.transform = `translate(${scrollPercent * 20}vw, ${scrollPercent * 50}vh) scale(${1 + scrollPercent * 0.5})`;
          }
          if (orb2) {
            // Moves from bottom-right to the left, while rotating
            orb2.style.transform = `translate(-${scrollPercent * 80}vw, -${scrollPercent * 30}vh) rotate(-${scrollPercent * 180}deg) scale(${1 + scrollPercent * 0.2})`;
          }
          if (orb3) {
            orb3.style.transform = `translate(-${scrollPercent * 10}vw, ${scrollPercent * 40}vh) scale(${1 + scrollPercent * 0.4})`;
          }
        });
      });
    </script>

    <Header />
    <slot />
    <Footer />
  </body>
</html>
